# Online Auction MVP — e2e Verification Contract
# Consumed by ~/Hermes/bin/e2e-verify to stand up the stack and run the acceptance suite.

MODE=compose
PORT=8010
BOARD=projects

# Stack lifecycle — single-quoted so sourcing doesn't execute them
UP='docker compose -f docker-compose.yml up --build -d --wait'
DOWN='docker compose -f docker-compose.yml down --volumes --remove-orphans'

# Readiness probe — must return HTTP 200
READY='curl -sf http://localhost:${PORT}/healthz'

# Log capture (for debugging failures)
LOGS='docker compose -f docker-compose.yml logs --tail=200'

# Acceptance test deps — black-box only (HTTP client + pytest)
TEST_DEPS='httpx pytest'

# Acceptance command — runs the black-box suite against the live port
ACCEPTANCE='API_BASE_URL="http://localhost:${PORT}" pytest -v verify/acceptance/'
