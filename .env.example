# ═══════════════════════════════════════════════════════════════════
# Online Auction MVP — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this to .env and fill in real values.  Never commit .env.
#   cp .env.example .env
#
# All variables have safe local-dev defaults that work against
# a compose-backed stack (db/redis on the compose network).
# ═══════════════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────────
# Async connection string for SQLAlchemy 2.0 + asyncpg.
# Default: connects to "db" service on compose network.
DATABASE_URL=postgresql+asyncpg://auction:auction@db:5432/auction

# ── Redis ────────────────────────────────────────────────────────
# Connection string for redis-py (asyncio).
# Default: connects to "redis" service on compose network.
REDIS_URL=redis://redis:6379/0

# ── App ──────────────────────────────────────────────────────────
# Host to bind the uvicorn server to.  0.0.0.0 for Docker.
HOST=0.0.0.0

# Port the uvicorn server listens on inside the container.
PORT=8000
