# ── Docker Compose ─────────────────────────────────────────────────
# Host port for the app (default 8010 — avoids collisions with 8000/5432/6379)
# APP_PORT=8010

# ── PostgreSQL ─────────────────────────────────────────────────────
# Connection string for asyncpg. Compose default: postgresql+asyncpg://auction:auction@db:5432/auction
# DATABASE_URL=postgresql+asyncpg://auction:auction@db:5432/auction

# ── Redis ──────────────────────────────────────────────────────────
# Connection string for redis.asyncio. Compose default: redis://redis:6379/0
# REDIS_URL=redis://redis:6379/0

# ── App (uvicorn bind) ─────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
